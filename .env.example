# ---- Claude authentication ---------------------------------------------------
# Subscription (Max/Pro/Team/Enterprise) via a long-lived OAuth token.
# Generate once on a machine with a browser:   claude setup-token
# Paste the printed token here. Do NOT also set ANTHROPIC_API_KEY — an API key
# takes precedence and switches billing back to pay-per-token credits.
CLAUDE_CODE_OAUTH_TOKEN=

# Alternative: pay-per-token with an Anthropic API key instead of the subscription.
# Leave this BLANK when using CLAUDE_CODE_OAUTH_TOKEN above.
# ANTHROPIC_API_KEY=

# ---- App access control (kept deliberately simple) ---------------------------
# A single shared secret. The server refuses to start if this is empty.
# Send it from the browser as the password on the login screen.
APP_TOKEN=change-me-to-a-long-random-string

# ---- Server ------------------------------------------------------------------
# Inside Docker, bind 0.0.0.0 so the published port is reachable from the host.
# For bare-metal local use you may prefer 127.0.0.1.
HOST=0.0.0.0
PORT=8787

# ---- Workspace mount ---------------------------------------------------------
# Host (or WSL) folder the agents can read — and, in read-write mode, modify and
# run shell commands in. Mounted at /workspace inside the container.
# Examples:  WORKSPACE_DIR=./workspace   WORKSPACE_DIR=C:\Users\you\docs
#            WORKSPACE_DIR=/mnt/c/Users/you/project   WORKSPACE_DIR=\\wsl$\Ubuntu\home\you\repo
WORKSPACE_DIR=./workspace

# ---- Pipeline tuning ---------------------------------------------------------
# Model per stage. Aliases (opus/sonnet/haiku) track the latest; you may pin a
# full id instead, e.g. claude-opus-4-8 / claude-sonnet-4-6 / claude-haiku-4-5.
PLAN_MODEL=opus
RESEARCH_MODEL=sonnet
EVAL_MODEL=opus
FACTCHECK_MODEL=sonnet
SYNTH_MODEL=opus

# How many research subtopics to fan out (the planner is asked for this many).
FANOUT_WIDTH=4
# Max research rounds (1 = plan+research once; 2 = allow one targeted follow-up).
MAX_ROUNDS=2
# How many worker agents run concurrently (caps subscription burst usage).
WORKER_CONCURRENCY=4
# Agentic turn budgets for the tool-using stages.
RESEARCH_MAX_TURNS=8
FACTCHECK_MAX_TURNS=6
