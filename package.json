{
  "name": "claude-research-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted, model-tiered deep-research assistant built on the Claude Agent SDK (headless).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.196",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
